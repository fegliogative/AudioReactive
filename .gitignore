# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist-info/
.eggs/
pip-wheel-metadata/
*.whl

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── PyInstaller build artefacts ──────────────────────────────────────────────
# These are generated by `build_mac.sh` / pyinstaller and must never be
# committed — they are hundreds of MB and machine-specific.
build/
dist/
*.spec.bak

# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Logs & temp files ────────────────────────────────────────────────────────
*.log
*.tmp
*.temp
tmp/
temp/

# ── Media / output files (large, generated) ──────────────────────────────────
*.mp4
*.mov
*.avi
*.mkv
*.wav
*.mp3

# ── Secrets ──────────────────────────────────────────────────────────────────
.env
*.pem
*.key
SoundReactive.dmg
